#primero cargamos los archisvos raster de Temperatura y Precipitacion
temp <- rast('CHELSA_tas_v2.1_20190601.tif')
pre <- rast('CHELSA_pr_v2.1_20190601.tif')
P <- pre*0.01
Te <- (temp*0.1-273)
#ejercico 3, utilizando la funcion Rast nos entregara los datos solicitados
rast(P)
rast(Te)
#utilizando las funciones especificas para cada dato solicitado
res(P)
cat(crs(P))
dim(P)
nrow(P)
ncol(P)
ncell(P)
res(Te)
cat(crs(Te))
dim(Te)
nrow(Te)
ncol(Te)
ncell(Te)
comunas <- st_read('division_comunal(1)/division_comunal.shp')
comunas <- st_read('division_comunal/division_comunal.shp')
#disolvemos las regiones
araucania <- comunas$NOM_REG == 'Región de La Araucanía'
region_araucania <- comunas[araucania,]
#gracias a esto pudimos separar la Region de la araucania y sus comunas
plot(region_araucania$geometry)
#ahora con geometry podemos obtener el poligono de la region
#ahora disolvemos la region
plot(st_union(region_araucania$geometry))
#ejercicio 5, Realizar corte de Temp y Pre para la region de La Araucania
#debemos cambiar el sistema de refrencia en relacion al raster
region_araucania <- st_transform(region_araucania,4326)
#para usar crop y mask hay que preocuparse que el dato vectorial este en spa vector, para obtenerlo de un dato sf se debe usar la funcion vect()
#mask(raster,vector) corta y elimina los valores faltantes
region_araucania_vect <- vect(st_union(region_araucania))
#ahiora utilizando mask vamos a realizar el corte
temp_araucania <- trim(mask(Te,region_araucania_vect))
plot(temp_araucania)
prec_araucania <- trim(mask(P,region_araucania_vect))
plot(prec_araucania)
estaciones <- st_read('estaciones_chile/estaciones_chile.shp')
#d utilizar la funcion extract para extraer los valores de pp en la ubicacion de las estaciones.
#primero pasamos estaciones a un spaVect
estaciones_vect <- vect(estaciones)
#ahora con la funcion extrac obtenemos las precipitaciones de las estaciones
prec_estaciones <- extract(P,estaciones_vect)
#ejercicio 7  remplazar valores 0 con NA y los valores <300mm con NA
#temperatura
temp_araucania[temp_araucania < 0] <- NA
#precipitaciones
prec_araucania[prec_araucania < 300] <- NA
